---
interface Props {
  title: string;
  description: string;
  tags: string[];
  href: string;
  github?: string;
  demo?: string;
  featured?: boolean;
}

const { title, description, tags, href, github, demo, featured = false } = Astro.props;
---

<a href={href} class:list={["block glass-card rounded-xl p-6 group", featured && "md:col-span-2"]}>
  <div class="flex items-start justify-between gap-4 mb-4">
    <h3 class="text-lg font-semibold text-text-primary group-hover:text-accent transition-colors">
      {title}
    </h3>
    <div class="flex items-center gap-2 shrink-0">
      {github && (
        <span class="text-text-muted hover:text-text-primary transition-colors" title="View source" aria-hidden="true">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
        </span>
      )}
      {demo && (
        <span class="text-text-muted hover:text-text-primary transition-colors" title="Live demo" aria-hidden="true">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </span>
      )}
    </div>
  </div>

  <p class="text-sm text-text-secondary mb-4 leading-relaxed">
    {description}
  </p>

  <div class="flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="text-xs px-2.5 py-1 rounded-full bg-accent-subtle text-accent font-medium">
        {tag}
      </span>
    ))}
  </div>
</a>
