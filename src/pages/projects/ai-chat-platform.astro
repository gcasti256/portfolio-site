---
import Layout from "../../layouts/Layout.astro";

const project = {
  title: "AI Chat Platform",
  description: "A full-featured chat application with streaming AI responses, multi-model support, and conversation persistence.",
  github: "https://github.com/georgecastillo/ai-chat-platform",
  demo: "#",
  tags: ["Next.js", "TypeScript", "Server-Sent Events", "AI", "SQLite", "Tailwind CSS"],
};

const features = [
  {
    title: "Streaming Responses",
    description: "Real-time token-by-token streaming using Server-Sent Events for instant feedback.",
  },
  {
    title: "Multi-Model Support",
    description: "Switch between OpenAI, Anthropic, and local models with a unified API layer.",
  },
  {
    title: "Conversation Persistence",
    description: "SQLite-backed storage with full-text search across conversation history.",
  },
  {
    title: "Prompt Engineering Sandbox",
    description: "Built-in panel to experiment with system prompts, temperature, and other parameters.",
  },
];

const techDecisions = [
  {
    choice: "Server-Sent Events over WebSockets",
    why: "SSE is simpler for unidirectional streaming, works through proxies and load balancers, and doesn't require a persistent connection.",
  },
  {
    choice: "SQLite over PostgreSQL",
    why: "Zero-config local development, portable database file, sufficient for single-user and demo purposes. Can migrate to Postgres for production.",
  },
  {
    choice: "tRPC for API layer",
    why: "End-to-end type safety between client and server without code generation or schema files.",
  },
];
---

<Layout title={`${project.title} — George Castillo`} description={project.description}>
  <section class="pt-32 pb-20 px-6">
    <div class="max-w-4xl mx-auto">
      <!-- Back link -->
      <a
        href="/projects"
        class="inline-flex items-center gap-1 text-sm text-text-muted hover:text-text-primary transition-colors mb-8"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Projects
      </a>

      <!-- Header -->
      <div class="mb-12">
        <h1 class="text-3xl font-bold text-text-primary mb-4">{project.title}</h1>
        <p class="text-lg text-text-secondary mb-6">{project.description}</p>

        <div class="flex flex-wrap gap-2 mb-6">
          {project.tags.map((tag) => (
            <span class="text-xs px-2.5 py-1 rounded-full bg-accent-subtle text-accent font-medium">
              {tag}
            </span>
          ))}
        </div>

        <div class="flex gap-4">
          <a
            href={project.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-border text-sm font-medium text-text-primary hover:bg-bg-hover transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
            Source Code
          </a>
          {project.demo !== "#" && (
            <a
              href={project.demo}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-accent text-white text-sm font-medium hover:bg-accent-hover transition-colors"
            >
              Live Demo
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          )}
        </div>
      </div>

      <!-- Screenshot placeholder -->
      <div class="rounded-xl border border-border overflow-hidden mb-16 bg-bg-surface aspect-video flex items-center justify-center">
        <span class="text-text-muted text-sm">Screenshot coming soon</span>
      </div>

      <!-- Features -->
      <div class="mb-16">
        <h2 class="text-xl font-bold text-text-primary mb-6">Key Features</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {features.map((feature) => (
            <div class="glass-card rounded-xl p-5">
              <h3 class="font-semibold text-text-primary mb-2">{feature.title}</h3>
              <p class="text-sm text-text-secondary">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Technical Decisions -->
      <div class="mb-16">
        <h2 class="text-xl font-bold text-text-primary mb-6">Technical Decisions</h2>
        <div class="space-y-4">
          {techDecisions.map((decision) => (
            <div class="glass-card rounded-xl p-5">
              <h3 class="font-semibold text-accent mb-2">{decision.choice}</h3>
              <p class="text-sm text-text-secondary">{decision.why}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Built with AI callout -->
      <div class="rounded-xl border border-accent/30 bg-accent-subtle p-6">
        <div class="flex items-start gap-4">
          <div class="p-2 rounded-lg bg-accent/20 text-accent shrink-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-text-primary mb-1">Built with AI</h3>
            <p class="text-sm text-text-secondary">
              This project was built using AI-augmented development workflows. Claude helped with
              architecture decisions, boilerplate generation, and debugging. The streaming implementation,
              API design, and UI were developed through iterative AI-assisted coding sessions,
              reducing development time by an estimated 60%.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
