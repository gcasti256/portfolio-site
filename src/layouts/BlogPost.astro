---
import Layout from "./Layout.astro";

interface Props {
  title: string;
  description: string;
  date: string;
  readTime: string;
  tags: string[];
}

const { title, description, date, readTime, tags } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={`${title} — George Castillo`} description={description}>
  <article class="pt-24 pb-16 px-6">
    <div class="max-w-3xl mx-auto">
      <!-- Back link -->
      <a
        href="/portfolio-site/blog"
        class="inline-flex items-center gap-2 text-sm text-text-muted hover:text-accent transition-colors mb-8"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Blog
      </a>

      <!-- Header -->
      <header class="mb-12">
        <div class="flex items-center gap-3 text-sm text-text-muted mb-4">
          <time datetime={date}>{formattedDate}</time>
          <span aria-hidden="true">·</span>
          <span>{readTime}</span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4 leading-tight">
          {title}
        </h1>
        <p class="text-lg text-text-secondary leading-relaxed">
          {description}
        </p>
        <div class="flex flex-wrap gap-2 mt-6">
          {tags.map((tag) => (
            <span class="px-3 py-1 text-xs font-medium rounded-full bg-accent-subtle text-accent">
              {tag}
            </span>
          ))}
        </div>
      </header>

      <!-- Content -->
      <div class="prose">
        <slot />
      </div>
    </div>
  </article>
</Layout>
